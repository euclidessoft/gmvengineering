{% extends 'layout.html.twig' %}

{% block home %}active{% endblock %}

{% block body %}

    <!-- Hero Section -->
    <section id="home" class="hero-section">
        <div class="hero-bg">
            <img src="{{ asset('images/hero-1.avif') }}" alt="Aircraft Engineering" class="hero-image">
            <div class="hero-overlay"></div>
        </div>

        <div class="container h-100">
            <div class="row h-100 align-items-center">
                <div class="col-lg-8 col-xl-7">
                    <div class="hero-content">
                        <h1 class="hero-title my-4">
                            <span class="title-primary">GMV ENGINEERING</span>
                        </h1>

                        <div class="hero-badge mb-4">
                            <span class="badge-text">{{ "La référence en ingénierie aéronautique"|trans }}</span>
                        </div>

                        <h1 class="hero-title mb-4">
                            <span class="title-secondary">{{ "Votre partenaire de confiance dans les cieux"|trans }}</span>
                        </h1>

                        <p class="hero-subtitle mb-5">
                            {{ "Expertise technique de pointe pour la maintenance, l'inspection et la gestion complète de votre flotte aérienne. Chez GMV Engineering, nous conjuguons innovation, rigueur et sécurité pour garantir l'excellence opérationnelle de vos aéronefs."|trans }}
                        </p>

                        <div class="hero-actions">
                            <a href="#services" class="btn btn-primary btn-cta me-3">
                                <span>{{ "Découvrez nos services"|trans }}</span>
                                <i class="arrow-icon">→</i>
                            </a>
                            <a href="#contact" class="btn btn-outline-light btn-secondary">
                                {{ "Contactez-nous"|trans }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="scroll-indicator">
            <div class="scroll-arrow"></div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="section-padding bg-light-blue">
        <div class="container">
            <div class="row">
                <div class="col-lg-6 mb-5">
                    <div class="section-header">
                        <span class="section-tag">{{ "À Propos"|trans }}</span>
                        <h2 class="section-title">{{ "Notre Histoire & Notre Vision"|trans }}</h2>
                    </div>

                    <div class="content-text">
                        <p class="lead">
                            {{ "Fondée par des experts,"|trans }} <strong>GMV ENGINEERING</strong> {{ "s'impose comme un acteur de référence dans le secteur aéronautique."|trans }}
                        </p>

                        <p>
                            {{ "Notre mission est de fournir des solutions techniques intégrées, allant de l'ingénierie de vol à la vente de pièces détachées certifiées, en passant par la maintenance préventive et corrective."|trans }}
                        </p>

                        <p>
                            {{ "Notre structure solide, dotée d'une expertise technique importante et d'une vision à long terme, assure à nos partenaires une fiabilité et un engagement sans faille."|trans }}
                        </p>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="about-image mb-4">
                        <img src="{{ asset('images/46754.avif') }}" alt="GMV Engineering Team"
                             class="img-fluid rounded-3 shadow-lg">
                    </div>
                </div>
            </div>

            <!-- Values -->
            <div class="row mt-5">
                <div class="col-12">
                    <h3 class="subsection-title text-center mb-5">{{ "Nos Valeurs"|trans }}</h3>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="value-card text-center">
                        <div class="value-icon">
                            <div class="icon-wrapper security"><i class="fa-solid fa-shield-halved fa-4x"></i></div>
                        </div>
                        <h4>{{ "Sécurité"|trans }}</h4>
                        <p>{{ "La priorité absolue dans chaque décision et chaque intervention."|trans }}</p>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="value-card text-center">
                        <div class="value-icon">
                            <div class="icon-wrapper excellence"><i class="fa-solid fa-web-awesome fa-4x"></i></div>
                        </div>
                        <h4>{{ "Excellence"|trans }}</h4>
                        <p>{{ "Une rigueur technique et un savoir-faire inégalé."|trans }}</p>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="value-card text-center">
                        <div class="value-icon">
                            <div class="icon-wrapper integrity"><i class="fa-solid fa-handshake fa-4x"></i></div>
                        </div>
                        <h4>{{ "Intégrité"|trans }}</h4>
                        <p>{{ "Des relations transparentes et honnêtes avec nos clients et fournisseurs."|trans }}</p>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="value-card text-center">
                        <div class="value-icon">
                            <div class="icon-wrapper innovation"><i class="fa-solid fa-lightbulb fa-4x"></i></div>
                        </div>
                        <h4>{{ "Innovation"|trans }}</h4>
                        <p>{{ "Une veille technologique constante pour des solutions toujours plus efficaces."|trans }}</p>
                    </div>
                </div>
            </div>

            <!-- Leadership -->
            <div class="row mt-5">
                <div class="col-12">
                    <div class="leadership-section text-center">
                        <h3 class="subsection-title mb-4">{{ "Notre Équipe de Direction"|trans }}</h3>
                        <p class="lead">
                            {{ "Dirigée par des professionnels expérimentés, notre gestion allie leadership éclairé et connaissance approfondie du terrain."|trans }}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="section-padding">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center mb-5">
                    <span class="section-tag">{{ "Services"|trans }}</span>
                    <h2 class="section-title">{{ "Une Offre de Services Complète et Intégrée"|trans }}</h2>
                    <p class="section-subtitle">
                        {{ "Chez GMV Engineering, nous comprenons que la disponibilité et la sécurité d'un aéronef reposent sur une multitude de facteurs. C'est pourquoi nous proposons une gamme de services synergiques pour couvrir tous vos besoins."|trans }}
                    </p>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="service-card h-100">
                        <div class="service-icon">
                        <span class="icon-bg flight">
                            <i class="fa-solid fa-gears"></i>
                        </span>
                        </div>
                        <div class="service-content">
                            <h4>{{ "Maintenance systématique"|trans }}</h4>
                            <p>
                                {{ "Identification et remplacement des pièces usées ou défectueuses, inspection et nettoyage plus ajustements du moteur, inspection de la cellule (fuselage, ailes, etc.), vérification du bon fonctionnement du système électrique, hydraulique et avionique."|trans }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="service-card h-100">
                        <div class="service-icon">
                        <span class="icon-bg maintenance">
                            <i class="fa-solid fa-wrench"></i>
                        </span>
                        </div>
                        <div class="service-content">
                            <h4>{{ "Maintenance & Inspection"|trans }}</h4>
                            <p>
                                {{ "Services complets de maintenance préventive et corrective, inspections régulières conformes aux réglementations en vigueur et diagnostics avancés pour garantir la parfaite navigabilité de votre appareil."|trans }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="service-card h-100">
                        <div class="service-icon">
                        <span class="icon-bg flight">
                            <i class="fa-solid fa-plane fa-rotate-by" style="--fa-rotate-angle: -45deg;"></i>
                        </span>
                        </div>
                        <div class="service-content">
                            <h4>{{ "Ingénierie de Vol"|trans }}</h4>
                            <p>
                                {{ "Expertise technique spécialisée pour l'analyse des performances, la planification des vols, la gestion du poids et de l'équilibrage, et le support technique opérationnel."|trans }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="service-card h-100">
                        <div class="service-icon">
                        <span class="icon-bg parts">
                            <i class="fa-solid fa-toolbox"></i>
                        </span>
                        </div>
                        <div class="service-content">
                            <h4>{{ "Vente de Pièces Aéronautiques"|trans }}</h4>
                            <p>
                                {{ "Approvisionnement et distribution de pièces détachées d'origine et certifiées pour une large gamme d'aéronefs. Notre réseau logistique assure rapidité et traçabilité."|trans }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="service-card h-100">
                        <div class="service-icon">
                        <span class="icon-bg flight">
                            <i class="fa-solid fa-screwdriver-wrench"></i>
                        </span>
                        </div>
                        <div class="service-content">
                            <h4>{{ "Réparation & Gestion des Pièces"|trans }}</h4>
                            <p>
                                {{ "Réparation sur mesure de composants, gestion optimisée des stocks de pièces et support technique 24/7 pour minimiser les temps d'immobilisation."|trans }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="service-card h-100">
                        <div class="service-icon">
                        <span class="icon-bg parts">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </span>
                        </div>
                        <div class="service-content">
                            <h4>{{ "Tests Préventifs"|trans }}</h4>
                            <p>
                                {{ "Mise en œuvre de programmes de tests et de contrôles non-destructifs pour anticiper les défaillances et assurer la continuité de service en toute sérénité."|trans }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-12 mb-4">
                    <div class="service-card h-100 featured text-center">
                        <div class="service-icon">
                            <span class="icon-bg why">💡</span>
                        </div>
                        <div class="service-content">
                            <h4>{{ "Pourquoi choisir GMV Eng ?"|trans }}</h4>
                            <ul class="why-list">
                                <li>🔧 {{ "Expertise reconnue dans le secteur aéronautique"|trans }}</li>
                                <li>⏱ {{ "Réactivité et flexibilité de nos équipes"|trans }}</li>
                                <li>🧩 {{ "Solutions sur mesure adaptées à vos contraintes opérationnelles"|trans }}</li>
                                <li>✅ {{ "Respect strict des normes de sécurité internationales"|trans }}</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-5">
                <div class="col-12 text-center">
                    <div class="mission-statement shadow">
                        <h3 class="mb-3">{{ "Notre Mission"|trans }}</h3>
                        <p class="lead">
                            {{ "Garantir la sécurité, la fiabilité et la disponibilité maximale de vos aéronefs."|trans }}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quality Section -->
    <section id="quality" class="section-padding bg-light-blue">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-5 mb-lg-0">
                    <div class="quality-image">
                        <img src="{{ asset('images/874.avif') }}" alt="Quality Standards"
                             class="img-fluid rounded-3 shadow-lg">
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="quality-content">
                        <span class="section-tag">{{ "Engagement Qualité"|trans }}</span>
                        <h2 class="section-title mb-4">{{ "La Conformité comme Pilier"|trans }}</h2>

                        <div class="quality-text">
                            <p class="lead mb-4">
                                {{ "Notre fonctionnement est strictement encadré par les dispositions de l'Acte Uniforme de l'OHADA relatif au droit commercial général."|trans }}
                            </p>

                            <p class="mb-4">
                                {{ "Cet ancrage juridique solide est le gage de notre sérieux, de notre transparence et de notre engagement à opérer dans le respect total des normes internationales et des législations locales."|trans }}
                            </p>

                            <div class="quality-highlight">
                                <div class="highlight-icon">✓</div>
                                <div class="highlight-text">
                                    <strong>{{ "Amélioration Continue"|trans }}</strong><br>
                                    {{ "Nous nous engageons dans une démarche d'amélioration continue de nos processus pour répondre aux exigences les plus strictes de l'industrie aéronautique."|trans }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section id="stats" class="section-padding stats-section">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center mb-5">
                    <span class="section-tag light">{{ "Chiffres Clés"|trans }}</span>
                    <h2 class="section-title light">{{ "Bref Aperçu"|trans }}</h2>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="stat-card text-center h-100">
                        <div class="stat-number" data-target="25">10</div>
                        <div class="stat-suffix">+ {{ "techniciens"|trans }}</div>
                        <div class="stat-label">{{ "expérimentés disponibles"|trans }}</div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="stat-card text-center h-100">
                        <div class="stat-number" data-target="25">25 000 000</div>
                        <div class="stat-suffix"></div>
                        <div class="stat-label">{{ "de capital social"|trans }}</div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="stat-card text-center h-100">
                        <div class="stat-number" data-target="100">100</div>
                        <div class="stat-suffix">%</div>
                        <div class="stat-label">{{ "de conformité aux normes"|trans }}</div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="stat-card text-center h-100">
                        <div class="stat-number" data-target="100">100</div>
                        <div class="stat-suffix">% {{ "engagé"|trans }}</div>
                        <div class="stat-label">{{ "pour votre satisfaction"|trans }}</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="section-padding">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center mb-5">
                    <span class="section-tag">{{ "Contact"|trans }}</span>
                    <h2 class="section-title">{{ "Prêts à Décoller Ensemble ?"|trans }}</h2>
                    <p class="section-subtitle">
                        {{ "Vous cherchez un partenaire de confiance pour accompagner vos opérations aériennes ?"|trans }}<br>
                        {{ "Discutons de votre projet et bâtissons ensemble l'avenir de votre flotte."|trans }}
                    </p>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <div class="contact-form">
                        <form id="contactForm">
                            <div class="row">
                                <div class="col-md-6 mb-5">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="name" required
                                               placeholder="Nom complet">
                                        <label for="name" class="form-label">{{ "Nom complet"|trans }}</label>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-5">
                                    <div class="form-floating">
                                        <input type="email" class="form-control" id="email" required placeholder="Email">
                                        <label for="email" class="form-label">Email</label>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-5">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="company" placeholder="Entreprise">
                                        <label for="company" class="form-label">Entreprise</label>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-5">
                                    <div class="form-floating">
                                        <input type="tel" class="form-control" id="phone" placeholder="Téléphone">
                                        <label for="phone" class="form-label">{{ "Téléphone"|trans }}</label>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-5">
                                <div class="form-floating">
                                    <select class="form-select" id="service">
                                        <option value="">{{ "Sélectionnez un service"|trans }}</option>
                                        <option value="maintenance">{{ "Maintenance systématique"|trans }}</option>
                                        <option value="inspection">{{ "Maintenance & Inspection"|trans }}</option>
                                        <option value="flight">{{ "Ingénierie de Vol"|trans }}</option>
                                        <option value="parts">{{ "Vente de Pièces"|trans }}</option>
                                        <option value="repair">{{ "Réparation & Gestion"|trans }}</option>
                                        <option value="testing">{{ "Tests Préventifs"|trans }}</option>
                                    </select>
                                    <label for="service" class="form-label">{{ "Service d'intérêt"|trans }}</label>
                                </div>
                            </div>
                            <div class="mb-5">
                                {#                            <div class="form-floating"> #}
                                <textarea class="form-control" id="message" rows="5"
                                          placeholder="{{ 'Décrivez votre projet ou vos besoins...'|trans }}"></textarea>
                                <label for="message" class="form-label"></label>
                                {#                            </div> #}
                            </div>
                            <div class="text-center">
                                <button type="submit" class="btn btn-primary btn-cta">
                                    <span>{{ "Envoyer le message"|trans }}</span>
                                    <i class="arrow-icon">→</i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Contact Info -->
            <div class="row mt-5">
                <div class="col-lg-4 mb-4">
                    <div class="contact-info-card text-center">
                        <div class="contact-icon"><i class="fa fa-location-dot fa-3x"></i></div>
                        <h5>{{ "Adresse"|trans }}</h5>
                        <p>
                            GMV ENGINEERING LTD<br>
                            {{ "Siège Social"|trans }} : 58 River Bank, Roseau, DOMINICA
                        </p>
                    </div>
                </div>

                <div class="col-lg-4 mb-4">
                    <div class="contact-info-card text-center">
                        <div class="contact-icon"><i class="fa fa-at fa-3x"></i></div>
                        <h5>Email</h5>
                        <p>
                            <a href="mailto:contact@gmvengineering.com">contact@gmvengineering.com</a>
                        </p>
                    </div>
                </div>

                <div class="col-lg-4 mb-4">
                    <div class="contact-info-card text-center">
                        <div class="contact-icon"><i class="fa fa-square-phone fa-3x"></i></div>
                        <h5>{{ "Téléphone"|trans }}</h5>
                        <p>
                            <a href="tel:+17676129056">+1 767 612 9056</a><br>
                            <a href="tel:+971523071828">+ 971 523 071 828</a><br>
                            <a href="tel:+237677700109">+ 237 677 700 109</a><br>
                            <small>{{ "Du lundi au vendredi"|trans }}<br>{{ "8h00 - 17h00"|trans }}</small>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}